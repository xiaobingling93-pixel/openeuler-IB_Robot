[submodule "libs/lerobot"]
    path = libs/lerobot
    url = git@gitcode.com:openeuler/lerobot_ros2.git
    branch = master
    ignore = dirty
[submodule "src/pymoveit2"]
	path = src/pymoveit2
	url = https://github.com/AndrejOrsula/pymoveit2.git
    branch = main
    ignore = dirty
[submodule "src/rosclaw"]
	path = src/rosclaw
	url = https://github.com/PlaiPin/rosclaw
[submodule "src/usb_cam"]
	path = src/usb_cam
	url = https://github.com/ros-drivers/usb_cam.git
	branch = main
